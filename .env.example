# Copy to .env and fill in values

# API
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://orchestrator:orchestrator@localhost:5432/orchestrator

# Redis
REDIS_URL=redis://localhost:6379

# Workspaces root — where project workspaces are mounted for OpenCode processes
WORKSPACES_ROOT=/workspaces

# GitHub Copilot token — used by OpenCode for all model calls
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Session budget cap (USD)
DEFAULT_BUDGET_CAP_USD=5

# Max parallel OpenCode processes
MAX_PARALLEL_AGENTS=4

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Nuxt frontend (apps/web/.env)
NUXT_PUBLIC_API_BASE=http://localhost:3001
NUXT_PUBLIC_WS_BASE=ws://localhost:3001

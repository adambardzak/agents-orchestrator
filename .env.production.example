# ─── Production env for VPS deployment ──────────────────────────────
# Copy to .env on the server (next to docker-compose.prod.yml).
# Do NOT commit a real version with secrets.

# Database
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=orchestrator

# GitHub Copilot OAuth token (or PAT) used by the API to call models.
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_TOKEN

# Public URLs — must be reachable from the user's browser.
# Note: NUXT_PUBLIC_API_BASE is the BASE only — the client appends `/api/...`.
PUBLIC_API_BASE=http://46.62.209.17:8091
PUBLIC_WS_BASE=ws://46.62.209.17:8091
CORS_ORIGINS=http://46.62.209.17:8091

LOG_LEVEL=info

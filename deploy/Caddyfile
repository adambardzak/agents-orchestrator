# Caddy reverse proxy for agent-orchestrator (Netcup VPS)
#
# Public surfaces:
#   https://agents.appitect.eu  → web (Nuxt) + /api/* + /ws/* proxied to api  (LE TLS, auto)
#   :8091                       → same routes (legacy plain-HTTP fallback during migration)
#   :8092                       → code-server (own login, served directly by code-server container)
#
# All public routes are protected by IP allowlist (defense-in-depth) + HTTP basic auth.

{
	admin off
	# auto_https is enabled by default; site blocks with hostnames will get LE certs.
	email adam.bardzak@gmail.com
}

# ─── Snippets reused by both site blocks ─────────────────────────────────────
(app_routes) {
	# IP allowlist (in front of basic auth).
	# Comma-separated CIDR list in $ALLOWED_IPS; default 0.0.0.0/0 = allow all.
	@blocked not client_ip {$ALLOWED_IPS:0.0.0.0/0}

	route {
		abort @blocked

		basic_auth {
			{$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
		}

		# Nuxt UI's icon server lives under /api/_nuxt_icon/* on the web app,
		# so it must be matched BEFORE the generic /api/* → fastify rule.
		handle /api/_nuxt_icon/* {
			reverse_proxy web:3000
		}

		# API prefix → fastify on :3001 inside docker network.
		handle /api/* {
			reverse_proxy api:3001
		}

		# WebSocket events.
		handle /ws/* {
			reverse_proxy api:3001
		}

		# Everything else → Nuxt
		handle {
			reverse_proxy web:3000
		}
	}

	encode zstd gzip

	log {
		output stdout
		format console
	}
}

# ─── Production HTTPS (Let's Encrypt) ────────────────────────────────────────
agents.appitect.eu {
	import app_routes
}

# ─── Legacy plain-HTTP fallback on :8091 ─────────────────────────────────────
# Kept temporarily so existing :8091 bookmarks / CI smoke checks continue to
# work during the HTTPS migration. Remove once everything points at the
# canonical hostname.
:8091 {
	import app_routes
}

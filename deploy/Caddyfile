# Caddy reverse proxy for agent-orchestrator (Netcup VPS)
# Public on :8091 with HTTP basic auth wrapping the Nuxt UI + API.
# code-server keeps its own login on :8092 (no Caddy in front).

{
	# Global options
	auto_https off
	admin off
}

:8091 {
	# IP allowlist (defense-in-depth, in front of basic auth).
	# Comma-separated list of CIDRs in $ALLOWED_IPS, e.g. "1.2.3.4/32,5.6.0.0/16".
	# Default 0.0.0.0/0 = allow all (basic auth still required).
	@blocked not client_ip {$ALLOWED_IPS:0.0.0.0/0}

	# `route` enforces explicit ordering; abort runs FIRST, before basic_auth/handle.
	route {
		abort @blocked

		# All paths require basic auth.
		basic_auth {
			{$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
		}

		# Nuxt UI's icon server lives under /api/_nuxt_icon/* on the web app,
		# so it must be matched BEFORE the generic /api/* → fastify rule.
		handle /api/_nuxt_icon/* {
			reverse_proxy web:3000
		}

		# API prefix → fastify on :3001 inside docker network.
		handle /api/* {
			reverse_proxy api:3001
		}

		# WebSocket events.
		handle /ws/* {
			reverse_proxy api:3001
		}

		# Everything else → Nuxt
		handle {
			reverse_proxy web:3000
		}
	}

	encode zstd gzip

	log {
		output stdout
		format console
	}
}
